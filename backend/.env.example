# Local development — use localhost:3308 (Docker exposes MariaDB on this host port)
DATABASE_URL=mysql+aiomysql://budget_user:budget_pass@localhost:3308/family_budget
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=43200
LOG_LEVEL=INFO
ENVIRONMENT=development

# For Docker deployment, these values live in /.env.docker (gitignored).
# docker-compose.yml loads that file via env_file for every service.
